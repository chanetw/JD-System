# ============================================
# DJ System - .gitignore
# ============================================

# ---------- Dependencies ----------
node_modules/
.pnpm-store/

# ---------- Lock files ----------
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lock

# ---------- Build outputs ----------
dist/
build/
.next/
out/
dist-ssr/

# ---------- Environment files ----------
.env
.env.*
!.env.example
!.env.*.example

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# ---------- OS files ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Cache ----------
.cache/
.parcel-cache/
.npm/
.eslintcache
*.tsbuildinfo

# ---------- Uploads (user-generated content) ----------
uploads/
backend/api-server/uploads/
!uploads/.gitkeep

# ---------- AI tool / Agent config folders ----------
.agent/
.agents/
.claude/
.gemini/
.opencode/
.windsurf/
CLAUDE.md
skills-lock.json

# ---------- Screenshots ----------
screenshots/

# ---------- Temporary / Debug / One-off scripts ----------
# Root-level debug scripts in backend/api-server/
backend/api-server/check_*.js
backend/api-server/check_*.cjs
backend/api-server/check_*.mjs
backend/api-server/debug_*.js
backend/api-server/debug_*.cjs
backend/api-server/apply_*.js
backend/api-server/verify_*.js
backend/api-server/inspect_*.js
backend/api-server/sync_*.mjs
backend/api-server/clean_*.js
backend/api-server/clear-cache.js
backend/api-server/test_*.js
backend/api-server/envprod.txt
backend/api-server/job39.json
# Scripts directory (one-off debug/check/fix scripts)
backend/api-server/src/scripts/
# Root backend test/debug files
backend/test.js
backend/test_*.js

# ---------- Database migration archives ----------
database/migrations/archived/
database/migrations/fixes/
database/migrations/manual/*verify*.sql

# ---------- Documentation (session/debug docs) ----------
docs/DEBUG_*.md
docs/sessions/

# ---------- Standalone HTML visualizations (generated/large) ----------
docs/workflows/*.html

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Misc ----------
*.pid
docs/~$*.xlsx
docs/~$*.docx

# Preview / standalone HTML files (not part of app)
job-detail-preview.html
frontend/password-preview.html
