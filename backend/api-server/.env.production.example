# ==========================================
# DJ System - Production Environment
# Copy this file to .env.production and update values
# ใช้สำหรับ deploy บน server จริง
# ==========================================

# Server
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ==========================================
# Database — Docker PostgreSQL (Production)
# ==========================================
DATABASE_MODE=local
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/dj_system

# ==========================================
# Storage — Local Disk (Docker Volume)
# ==========================================
STORAGE_PROVIDER=local
UPLOADS_DIR=/app/uploads

# ==========================================
# Auth
# ==========================================
AUTH_MODE=jwt_only
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# ==========================================
# File Retention
# ==========================================
FILE_RETENTION_DAYS=30

# ==========================================
# Email
# ==========================================
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_API_URL=http://localhost:3001
EMAIL_API_KEY=CHANGE_ME

# ==========================================
# Feature Flags
# ==========================================
ENABLE_NOTIFICATIONS=true
ENABLE_RATE_LIMITING=true

# ==========================================
# Job Chaining
# ==========================================
MAX_CHAIN_DEPTH=3
ENABLE_FULL_TRANSITIVE=true
PREVENT_SELF_CHAIN=true
ENABLE_CYCLE_DETECTION=true
URGENT_SHIFT_DAYS=2
ENABLE_URGENT_RESCHEDULE=true
ENABLE_CHAIN_NOTIFICATIONS=true
