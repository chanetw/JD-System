# ==========================================
# DJ System - Local Docker Environment
# Copy this file to .env.local and update values
# ใช้สำหรับ development โดยไม่พึ่ง Supabase cloud
# ==========================================

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# Database — Local Docker PostgreSQL
# ==========================================
DATABASE_MODE=local
DATABASE_URL=postgresql://postgres:password@localhost:5433/dj_system

# ==========================================
# Storage — Local Disk (Docker Volume)
# ==========================================
STORAGE_PROVIDER=local
UPLOADS_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ==========================================
# Auth
# ==========================================
AUTH_MODE=jwt_only
JWT_SECRET=your-super-secret-key-change-this-locally

# ==========================================
# File Retention
# ==========================================
FILE_RETENTION_DAYS=7

# ==========================================
# Email (Optional — ปิดได้สำหรับ local dev)
# ==========================================
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_API_URL=http://localhost:3001
EMAIL_API_KEY=local-dev-key

# ==========================================
# Feature Flags
# ==========================================
ENABLE_NOTIFICATIONS=true
ENABLE_RATE_LIMITING=false

# ==========================================
# Job Chaining
# ==========================================
MAX_CHAIN_DEPTH=3
ENABLE_FULL_TRANSITIVE=true
PREVENT_SELF_CHAIN=true
ENABLE_CYCLE_DETECTION=true
URGENT_SHIFT_DAYS=2
ENABLE_URGENT_RESCHEDULE=true
URGENT_IMPACT_TEST_EMAIL=chanetw@sena.co.th
ENABLE_CHAIN_NOTIFICATIONS=true
